# data.gov.in — register free at https://data.gov.in for a personal API key.
# The bundled sample key is capped at 10 rows; a registered key returns ~3,500.
DATAGOV_API_KEY=your_api_key_here
DATAGOV_RESOURCE_ID=3b01bcb8-0b14-4abf-b6f2-c1bfd384ba69

# Local dev uses a SQLite file by default (no config needed):
# DATABASE_URL=file:./airq.db

# Production (Vercel): use Turso/libSQL so the DB survives serverless.
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your_token

# Protects the /api/ingest cron route in production.
# CRON_SECRET=some_long_random_string
